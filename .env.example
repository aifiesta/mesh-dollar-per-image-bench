# Copy this file to `.env` and fill in your own values.
# Never commit `.env` to git. It's already in .gitignore.

# Get your key from the Mesh API dashboard. Rotate from any previous session.
MESH_API_KEY=rsk_your_key_here

# Base URL. The /v1 suffix is required.
MESH_BASE_URL=https://api.meshapi.ai/v1

# Optional: local cache dir for VQA and aesthetic model weights (judge_auto.py)
# Defaults to ~/.cache/image-bench if unset.
# IMAGE_BENCH_CACHE_DIR=/path/to/cache

# Optional: override the vision-judge model IDs (defaults match models.py)
# JUDGE_VISION_PRIMARY=anthropic/claude-opus-4.7
# JUDGE_VISION_SECONDARY=openai/gpt-5.5
